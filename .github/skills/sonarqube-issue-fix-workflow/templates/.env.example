# SonarQube Local Setup Environment Variables
# Created by sonarqube-setup.sh
# DO NOT commit this file to version control

SONARQUBE_URL="http://localhost:9000"
SONARQUBE_TOKEN="<YOUR_TOKEN_HERE>"
SONARQUBE_USER="admin"
SONARQUBE_PASSWORD="admin"

# Database connection (for reference only)
POSTGRES_URL="postgresql://sonar:sonarpassword@localhost:5432/sonarqube"

# Project configuration
PROJECT_KEY="local-project"
LANGUAGES_DETECTED="auto"

# Docker container names
SONARQUBE_CONTAINER="sonarqube"
POSTGRES_CONTAINER="sonarqube-postgres"
DOCKER_NETWORK="sonarqube-network"

# Scan configuration
MIN_SEVERITY="HIGH"
QUALITY_GATE_TIMEOUT="300"
